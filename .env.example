# Docker/PostgreSQL local development settings.
# Copy this file to .env at the project root only when you need to override Docker Compose defaults.

# Database name created inside the PostgreSQL container
POSTGRES_DB=salon_booking

# Database user created inside the PostgreSQL container
POSTGRES_USER=salon_user

# Password for the PostgreSQL container user
POSTGRES_PASSWORD=salon_password

# Host port exposed by Docker Compose for local database access
POSTGRES_PORT=5432
