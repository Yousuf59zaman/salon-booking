# Database connection string used by Prisma to connect to the PostgreSQL database
DATABASE_URL="postgresql://salon_user:salon_password@localhost:5432/salon_booking?schema=public"

# The secret key used to sign and verify JWT authentication tokens (Must be replaced with a strong random string in production)
JWT_SECRET="replace-with-a-long-random-secret"

# The URL of the client application (Frontend) allowed to make CORS requests to this backend
FRONTEND_URL="http://localhost:3000"

# Default admin email seeded into the database on initialization
ADMIN_EMAIL="admin@glamcut.local"

# Default admin password seeded into the database (Must be changed before running in production)
ADMIN_PASSWORD="change-this-password"

# The port number on which the backend server will listen
PORT=3001
